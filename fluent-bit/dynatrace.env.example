# ============================================================================
# Configuración de Dynatrace para Fluent Bit (LABORATORIO).
# Copia este archivo a "dynatrace.env" y coloca tus valores reales.
#   cp dynatrace.env.example dynatrace.env
# El archivo dynatrace.env está ignorado por git (no se versiona el token).
# ============================================================================

# Host del entorno Dynatrace SIN el prefijo https:// y SIN ruta.
#   - SaaS:        <env-id>.live.dynatrace.com
#   - Managed/AG:  <activegate-host>   (el path /e/<env-id> va en metrics_uri)
DYNATRACE_HOST=CHANGEME.live.dynatrace.com

# Token de ingesta (API token). Para métricas requiere el scope: metrics.ingest
# (más adelante, para logs, añadiremos el scope logs.ingest).
DYNATRACE_API_TOKEN=dt0c01.CHANGEME
