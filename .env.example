# ==== DynaDemoCap · Exchange Simulado ====
# Copia este archivo a .env y ajusta los valores.
# El paso de "seed" intenta UNA llamada a exchangerate; si falla o no hay clave,
# usa un fallback embebido para que la app sea ejecutable de inmediato.

# Credenciales de la API externa (placeholders válidos para arrancar la demo)
EXCHANGERATE_API_KEY=demo-placeholder-key
EXCHANGERATE_BASE_URL=https://api.exchangerate.host/latest

# Puertos de los servicios (configurables)
SIM_PORT=4001
PERSIST_PORT=4002
FRONTEND_PORT=5173
